# ClientFlow AI — Environment Variables
# Copy this file to .env.local and fill in real values.
# DO NOT commit .env.local to version control.

# ──────────────────────────────────────────────────────
# OpenAI API Key (for AI Tools, Proposals, Email Writer)
# Get yours at: https://platform.openai.com/api-keys
# ──────────────────────────────────────────────────────
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────
# Supabase (optional — app runs in mock mode without it)
# Get yours at: https://supabase.com/dashboard
# ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────
# App URL (used for canonical links, OG images, etc.)
# Set to your Vercel production URL when deploying
# ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
